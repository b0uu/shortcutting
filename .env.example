# Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# Server-only elevated key. Prefer the new Supabase Secret key (`sb_secret_...`).
# Do not expose this to the browser.
SUPABASE_SECRET_KEY=YOUR_SUPABASE_SECRET_KEY

# Legacy fallback only. Use this if your project does not offer Secret keys yet.
# SUPABASE_SERVICE_ROLE_KEY=YOUR_LEGACY_SERVICE_ROLE_KEY

# Used by metadata/auth redirect setup in deployment.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Auth redirect URLs to configure:
# http://localhost:3000/auth/callback
# https://YOUR_PRODUCTION_DOMAIN/auth/callback

# OAuth TODO, not implemented in this pass:
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
